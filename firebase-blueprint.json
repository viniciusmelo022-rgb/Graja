{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing points, level, and roles.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telefone": { "type": "string" },
        "tipo": { "type": "string", "enum": ["dono_master", "admin", "operador", "financeiro", "suporte", "restaurante", "entregador", "cliente"] },
        "pontos": { "type": "number" },
        "nivel": { "type": "string" },
        "ativo": { "type": "boolean" }
      },
      "required": ["id", "nome", "email", "tipo", "ativo"]
    },
    "Address": {
      "title": "Address",
      "description": "User saved addresses.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "usuario_id": { "type": "string" },
        "logradouro": { "type": "string" },
        "numero": { "type": "string" },
        "bairro": { "type": "string" },
        "complemento": { "type": "string" },
        "principal": { "type": "boolean" }
      },
      "required": ["id", "usuario_id", "logradouro", "numero", "bairro", "principal"]
    },
    "Restaurant": {
      "title": "Restaurant",
      "description": "Restaurant operating in Graja Food.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "descricao": { "type": "string" },
        "categoria": { "type": "string" },
        "logo_url": { "type": "string", "format": "uri" },
        "pedido_minimo": { "type": "number" },
        "tempo_preparo": { "type": "number" },
        "avaliacao_media": { "type": "number" },
        "total_avaliacoes": { "type": "number" },
        "logradouro": { "type": "string" },
        "bairro": { "type": "string" }
      },
      "required": ["id", "nome", "categoria", "pedido_minimo", "tempo_preparo"]
    },
    "Product": {
      "title": "Product",
      "description": "Menu product list for a specific restaurant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "restaurante_id": { "type": "string" },
        "nome": { "type": "string" },
        "descricao": { "type": "string" },
        "preco": { "type": "number" },
        "categoria": { "type": "string" }
      },
      "required": ["id", "restaurante_id", "nome", "preco", "categoria"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer placements.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "usuario_id": { "type": "string" },
        "restaurante_id": { "type": "string" },
        "restaurante_nome": { "type": "string" },
        "restaurante_logo": { "type": "string" },
        "itens": { "type": "array" },
        "endereco": { "type": "string" },
        "subtotal": { "type": "number" },
        "taxa": { "type": "number" },
        "total": { "type": "number" },
        "forma_pagamento": { "type": "string" },
        "status": { "type": "string", "enum": ["recebido", "preparando", "saiu_para_entrega", "entregue", "cancelado"] },
        "criado_em": { "type": "string", "format": "date-time" },
        "atualizado_em": { "type": "string", "format": "date-time" },
        "pontos_ganhos": { "type": "number" }
      },
      "required": ["id", "usuario_id", "restaurante_id", "itens", "endereco", "subtotal", "taxa", "total", "status", "criado_em"]
    },
    "Invite": {
      "title": "Invite",
      "description": "Invitation generated by Master Admin for new staff.",
      "type": "object",
      "properties": {
        "token": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "tipo": { "type": "string" },
        "permissoes": { "type": "object" },
        "criado_em": { "type": "string", "format": "date-time" }
      },
      "required": ["token", "email", "tipo", "criado_em"]
    },
    "Log": {
      "title": "Log",
      "description": "Activity action logs for admin auditing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "usuario_id": { "type": "string" },
        "acao": { "type": "string" },
        "detalhes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "usuario_id", "acao", "detalhes", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile metadata searchable on sign-in."
    },
    "/users/{userId}/addresses/{addressId}": {
      "schema": { "$ref": "#/entities/Address" },
      "description": "Client saved delivery addresses."
    },
    "/restaurants/{restaurantId}": {
      "schema": { "$ref": "#/entities/Restaurant" },
      "description": "Public directory of food restaurants."
    },
    "/restaurants/{restaurantId}/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "The menu product options under each restaurant."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Secure placed delivery orders."
    },
    "/invites/{token}": {
      "schema": { "$ref": "#/entities/Invite" },
      "description": "Invitation tokens created by Dono Master."
    },
    "/logs/{logId}": {
      "schema": { "$ref": "#/entities/Log" },
      "description": "Audit logging for the backoffice."
    }
  }
}
